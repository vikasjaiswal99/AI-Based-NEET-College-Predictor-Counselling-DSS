# ── Copy to .env and fill in your values ──────────
# DO NOT commit .env to version control

DJANGO_SECRET_KEY=replace-with-a-long-random-string-at-least-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── SQLite (file-based, no external DB server) ───
# Path is resolved relative to BASE_DIR in settings.py if you keep it as a simple filename.
SQLITE_DB_PATH=db.sqlite3

# ── CORS (for React/mobile frontend) ──────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── ML Dataset path (absolute or relative to BASE_DIR) ──
# ML_CSV_PATH=/absolute/path/to/neet_cutoffs.csv
